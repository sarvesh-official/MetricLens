# Slack tokens (from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token

# PostHog API (from PostHog project settings)
POSTHOG_API_KEY=phx_your-personal-api-key
POSTHOG_PROJECT_ID=your-project-id
POSTHOG_HOST=https://us.posthog.com

# Slack channel where daily/weekly reports are posted
SLACK_REPORT_CHANNEL=general
